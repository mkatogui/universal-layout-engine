{
  "name": "@mkatogui/ule-renderers",
  "version": "0.1.0",
  "type": "module",
  "description": "Multi-platform renderers for Universal Layout Engine",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./web": "./dist/web/index.js",
    "./ios": "./dist/ios/index.js",
    "./android": "./dist/android/index.js",
    "./desktop": "./dist/desktop/index.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mkatogui/ule-core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
